# ============================================================================
# MASTER PIPELINE CONFIGURATION
# ============================================================================

# ----------------------------------------------------------------------------
# WORKSPACE PATHS
# ----------------------------------------------------------------------------
PIPELINE_WORKSPACE=pipeline_workspace
DOWNLOADED_IMAGES_DIR=01_downloaded_from_drive
UNIQUE_IMAGES_DIR=02_unique_images
DUPLICATE_CLUSTERS_DIR=02_duplicate_clusters
BIOMETRIC_PROCESSED_DIR=03_biometric_processed
FINAL_OUTPUT_DIR=04_final_output

# ----------------------------------------------------------------------------
# BIOMETRIC COMPLIANCE PIPELINE PATHS
# ----------------------------------------------------------------------------
BIOMETRIC_PIPELINE_DIR=biometric_compliance_pipeline
BIOMETRIC_INPUT_DIR=data/input
BIOMETRIC_OUTPUT_DIR=data/obfuscated
BIOMETRIC_CLEAN_DIR=data/clean
BIOMETRIC_QA_DIR=data/qa_review
BIOMETRIC_RESULTS_DIR=results
BIOMETRIC_LOGS_DIR=results/logs

# ----------------------------------------------------------------------------
# DEDUPLICATION SETTINGS
# ----------------------------------------------------------------------------
DEDUP_THRESHOLD=10
USE_LLM_VALIDATION=false
MAX_LLM_VALIDATIONS=100

# ----------------------------------------------------------------------------
# FACE DETECTION & OBFUSCATION SETTINGS
# ----------------------------------------------------------------------------
FACE_DETECTION_CONFIDENCE=0.5
FACE_VERIFICATION_THRESHOLD=0.4
OBFUSCATION_METHOD=egoblur
FILTER_ANIMAL_FACES=true
YOLO_MODEL=yolov8n.pt

# ----------------------------------------------------------------------------
# GOOGLE DRIVE CONFIGURATION (Optional - only if using download step)
# ----------------------------------------------------------------------------
GOOGLE_DRIVE_FOLDER_ID=1orx__x-85P5tGSkhMc-mw03-bBIA0BrA
GOOGLE_SERVICE_ACCOUNT_FILE=turing-genai-ws-58339643dd3f.json

# ----------------------------------------------------------------------------
# OPENAI API (Optional - only if using LLM validation)
# ----------------------------------------------------------------------------
# OPENAI_API_KEY=your_openai_api_key_here

# ----------------------------------------------------------------------------
# AWS S3 CONFIGURATION (Optional - only if using S3 upload)
# ----------------------------------------------------------------------------
# AWS_ACCESS_KEY_ID=your_aws_access_key
# AWS_SECRET_ACCESS_KEY=your_aws_secret_key
# AWS_REGION=us-east-1
# S3_BUCKET_NAME=your-bucket-name

# ----------------------------------------------------------------------------
# DATABASE CONFIGURATION
# ----------------------------------------------------------------------------
DATABASE_URL=sqlite:///./photo_annotation.db

# ----------------------------------------------------------------------------
# PIPELINE BEHAVIOR
# ----------------------------------------------------------------------------
VERBOSE_LOGGING=true
NUM_WORKERS=4
PIPELINE_TIMEOUT=3600
CLEANUP_TEMP_FILES=true

# ----------------------------------------------------------------------------
# OUTPUT FORMAT SETTINGS
# ----------------------------------------------------------------------------
OUTPUT_FORMAT=jpg
JPEG_QUALITY=95
PRESERVE_ORIGINAL_FORMAT=true

# ----------------------------------------------------------------------------
# DEVELOPMENT/DEBUG SETTINGS
# ----------------------------------------------------------------------------
DEBUG=false
DRY_RUN=false
# LIMIT_IMAGES=10

# ----------------------------------------------------------------------------
# APPLICATION SETTINGS (for annotation tool integration)
# ----------------------------------------------------------------------------
SECRET_KEY=972d733d9d2f2985db4db351657a30335187fc57187f112502fee8c6fc3fb4b0
CORS_ORIGINS=http://localhost:3000,http://localhost:5173


# ----------------------------------------------------------------------------
# DEFAULT PIPELINE STEPS (what runs when no flags specified)
# ----------------------------------------------------------------------------
# Set which steps should run by default
RUN_DOWNLOAD_BY_DEFAULT=false
RUN_DEDUPLICATE_BY_DEFAULT=false
RUN_BIOMETRIC_BY_DEFAULT=false
RUN_ALL_BY_DEFAULT=true


# Default Admin Users (JSON format)
SEED_ADMINS=[{"username":"admin","password":"admin123","full_name":"Administrator"}]
